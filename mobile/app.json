{
  "expo": {
    "name": "WoltMobile",
    "slug": "wolt-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "woltmobile",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": { "supportsTablet": true },
    "android": { "adaptiveIcon": { "foregroundImage": "./assets/adaptive-icon.png", "backgroundColor": "#009DE0" } },
    "plugins": ["expo-router"],
    "experiments": { "typedRoutes": false }
  }
}